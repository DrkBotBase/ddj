            const modal = document.getElementById('modal-content');
            modal.innerHTML = `
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold">Detalles de la Orden #${order.shortId || order._id.slice(-6)}</h3>
                    <button onclick="closeModal()" class="neumorphic-button p-2 rounded-full"><i data-lucide="x"></i></button>
                </div>
                <div class="space-y-6">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="neumorphic-input p-4 rounded-xl">
                            <h4 class="text-xs uppercase text-gray-500 mb-2">Cliente</h4>
                            <p class="font-bold text-sm">${order.clientName}</p>
                            <p class="text-sm">${order.clientPhone}</p>
                            <p class="text-xs text-gray-400">${order.clientAddress}</p>
                        </div>
                        <div class="neumorphic-input p-4 rounded-xl">
                            <h4 class="text-xs uppercase text-gray-500 mb-2">Pago y Estado</h4>
                            <p class="text-sm">Método: <span class="font-bold uppercase">${order.paymentMethod}</span></p>
                            ${order.paymentMethod === 'multipago' ? `
                                <div class="mt-1 text-[11px] text-gray-400">
                                    <p>💵 Efectivo: $${(order.cashAmount || 0).toLocaleString()}</p>
                                    <p>💳 Transf: $${(order.transferAmount || 0).toLocaleString()}</p>
                                </div>
                            ` : (order.cashAmount ? `<p class="text-sm">Paga con: <strong>$${order.cashAmount.toLocaleString()}</strong></p>` : '')}
                            <div class="mt-2">
                                <span class="text-[10px] px-2 py-0.5 rounded-full ${getStatusClass(order.status)} uppercase font-bold">${order.status}</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="neumorphic-input p-4 rounded-xl">
                        <h4 class="text-xs uppercase text-gray-500 mb-2">Productos</h4>
                        <div class="space-y-2">
                            ${order.items.map(item => `
                                <div class="flex justify-between text-sm border-b border-white/5 pb-1">
                                    <span>${item.quantity}x ${item.name}</span>
                                    <span>$${(item.price * item.quantity).toLocaleString()}</span>
                                </div>
                                ${item.adicionales && item.adicionales.length > 0 ? `
                                    <div class="text-[10px] text-gray-400 pl-4">
                                        ${item.adicionales.map(a => `+ ${a.name} ($${a.price.toLocaleString()})`).join('<br>')}
                                    </div>
                                ` : ''}
                                ${item.instructions ? `<p class="text-[10px] italic text-gray-500 pl-4">"${item.instructions}"</p>` : ''}
                            `).join('')}
                        </div>
                        <div class="mt-4 pt-2 border-t border-[var(--light-shadow)] space-y-1">
                            <div class="flex justify-between text-xs text-gray-400"><span>Subtotal</span><span>$${order.subtotal.toLocaleString()}</span></div>
                            <div class="flex justify-between text-xs text-gray-400"><span>Envío</span><span>$${order.shippingCost.toLocaleString()}</span></div>
                            <div class="flex justify-between font-bold text-lg pt-1" style="color: var(--primary-color);"><span>TOTAL</span><span>$${order.total.toLocaleString()}</span></div>
                        </div>
                    </div>

                    ${order.comments ? `
                        <div class="neumorphic-input p-4 rounded-xl">
                            <h4 class="text-xs uppercase text-gray-500 mb-1">Comentarios</h4>
                            <p class="text-sm italic">"${order.comments}"</p>
                        </div>
                    ` : ''}

                    <div class="flex gap-4">
                        <select onchange="updateOrderStatus('${order._id}', this.value); closeModal();" class="flex-grow neumorphic-input p-3 rounded-xl text-sm">
                            <option value="pending" ${order.status === 'pending' ? 'selected' : ''}>Pendiente</option>
                            <option value="completed" ${order.status === 'completed' ? 'selected' : ''}>Completada</option>
                            <option value="cancelled" ${order.status === 'cancelled' ? 'selected' : ''}>Cancelada</option>
                        </select>
                        <button onclick="deleteOrder('${order._id}'); closeModal();" class="neumorphic-button p-3 rounded-xl text-red-500">
                            <i data-lucide="trash-2"></i>
                        </button>
                    </div>
                </div>
            `;
            document.getElementById('modal-overlay').classList.remove('hidden');
            lucide.createIcons();
        }

        function getStatusClass(status) {
            switch(status) {
                case 'completed': return 'bg-green-500/20 text-green-500';
                case 'cancelled': return 'bg-red-500/20 text-red-500';
                default: return 'bg-yellow-500/20 text-yellow-500';
            }
        }

        async function updateOrderStatus(id, status) {
            const res = await fetch(`/api/admin/orders/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            if (res.ok) loadOrders();
        }

        async function deleteOrder(id) {
            if (!confirm('¿Eliminar registro de la orden?')) return;
            const res = await fetch(`/api/admin/orders/${id}`, { method: 'DELETE' });
            if (res.ok) loadOrders();
        }

        // --- Configuración ---
        document.getElementById('config-form').onsubmit = async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = {
                config: {
                    nombre: formData.get('nombre'),
                    direccion: formData.get('direccion'),
                    telefonoWhatsApp: formData.get('telefonoWhatsApp'),
                    logoUrl: formData.get('logoUrl'),
                    color: {
                        primary: formData.get('color_primary'),
                        bg: formData.get('color_bg'),
                        text: formData.get('color_text'),
                        light: formData.get('color_light'),
                        dark: formData.get('color_dark')
                    }
                }
            };

            const res = await fetch('/api/restaurant-info', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) showToast('Configuración guardada.', 'success');
        };

        // --- Menú ---
        async function loadCategories() {
            const res = await fetch('/api/menu-categories');
            menuCategories = await res.json();
            renderMenu();
        }

        function renderMenu() {
            const container = document.getElementById('categories-container');
            container.innerHTML = '';

            menuCategories.forEach(cat => {
                const catEl = document.createElement('div');
                catEl.className = 'neumorphic-flat rounded-2xl p-6';
                catEl.innerHTML = `
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-xl font-bold flex items-center gap-2">
                            ${cat.category}
                            <span class="text-xs ${cat.active ? 'text-green-500' : 'text-red-500'} font-normal">
                                (${cat.active ? 'Activa' : 'Desactivada'})
                            </span>
                        </h3>
                        <div class="flex gap-2">
                            <button onclick="openItemModal('${cat._id}')" class="text-sm neumorphic-button px-3 py-1 rounded-lg flex items-center gap-1">
                                <i data-lucide="plus" class="w-3 h-3"></i> Item
                            </button>
                            <button onclick="editCategory('${cat._id}')" class="text-sm neumorphic-button px-3 py-1 rounded-lg">
                                <i data-lucide="edit-2" class="w-3 h-3"></i>
                            </button>
                            <button onclick="deleteCategory('${cat._id}')" class="text-sm neumorphic-button px-3 py-1 rounded-lg text-red-500">
                                <i data-lucide="trash-2" class="w-3 h-3"></i>
                            </button>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        ${cat.items.map(item => `
                            <div class="neumorphic-input rounded-xl p-4 flex justify-between items-center ${!item.active ? 'opacity-50' : ''}">
                                <div>
                                    <p class="font-bold text-sm">${item.name}</p>
                                    <p class="text-xs text-gray-400">$${item.basePrice.toLocaleString()}</p>
                                </div>
                                <div class="flex gap-2">
                                    <button onclick="editItem('${cat._id}', '${item._id}')" class="p-2 neumorphic-button rounded-lg">
                                        <i data-lucide="edit-3" class="w-3 h-3"></i>
                                    </button>
                                    <button onclick="deleteItem('${cat._id}', '${item._id}')" class="p-2 neumorphic-button rounded-lg text-red-500">
                                        <i data-lucide="x" class="w-3 h-3"></i>
                                    </button>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                `;
                container.appendChild(catEl);
            });
            lucide.createIcons();
        }

        function openCategoryModal(catId = null) {
            const cat = catId ? menuCategories.find(c => c._id === catId) : null;
            const modal = document.getElementById('modal-content');
            modal.innerHTML = `
                <h3 class="text-xl font-bold mb-4">${cat ? 'Editar' : 'Nueva'} Categoría</h3>
                <form id="category-form" class="space-y-4">
                    <div>
                        <label class="block text-sm mb-1">Nombre de la Categoría</label>
                        <input type="text" id="cat-name" value="${cat ? cat.category : ''}" required class="w-full neumorphic-input p-3 rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Orden (número)</label>
                        <input type="number" id="cat-order" value="${cat ? cat.order : 0}" class="w-full neumorphic-input p-3 rounded-lg">
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="cat-active" ${cat ? (cat.active ? 'checked' : '') : 'checked'} class="w-4 h-4">
                        <label class="text-sm">Categoría Activa</label>
                    </div>
                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="flex-grow neumorphic-button py-3 rounded-xl font-bold" style="background-color: var(--primary-color); color: black;">Guardar</button>
                        <button type="button" onclick="closeModal()" class="flex-grow neumorphic-button py-3 rounded-xl font-bold">Cancelar</button>
                    </div>
                </form>
            `;
            document.getElementById('category-form').onsubmit = async (e) => {
                e.preventDefault();
                const data = {
                    category: document.getElementById('cat-name').value,
                    order: parseInt(document.getElementById('cat-order').value),
                    active: document.getElementById('cat-active').checked
                };
                const res = await fetch(cat ? `/api/menu-categories/${cat._id}` : '/api/menu-categories', {
                    method: cat ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (res.ok) { closeModal(); loadCategories(); }
            };
            document.getElementById('modal-overlay').classList.remove('hidden');
        }

        function addAdicionalRow(ad = null) {
            const container = document.getElementById('adicionales-container');
            const row = document.createElement('div');
            row.className = 'flex flex-wrap gap-2 adicional-row neumorphic-pressed p-2 rounded-lg';
            row.innerHTML = `
                <input type="text" placeholder="Nombre (ej: Combo)" value="${ad ? ad.name : ''}" class="flex-grow neumorphic-input p-2 rounded-lg text-xs ad-name">
                <input type="number" placeholder="Precio" value="${ad ? ad.price : ''}" class="w-20 neumorphic-input p-2 rounded-lg text-xs ad-price">
                <select class="w-24 neumorphic-input p-2 rounded-lg text-xs ad-type">
                    <option value="checkbox" ${ad && ad.type === 'checkbox' ? 'selected' : ''}>Múltiple</option>
                    <option value="radio" ${ad && ad.type === 'radio' ? 'selected' : ''}>Único</option>
                </select>
                <button type="button" onclick="this.parentElement.remove()" class="p-2 neumorphic-button rounded-lg text-red-500">
                    <i data-lucide="trash-2" class="w-3 h-3"></i>
                </button>
            `;
            container.appendChild(row);
            lucide.createIcons();
        }

        function openItemModal(catId, itemId = null) {
            const cat = menuCategories.find(c => c._id === catId);
            const item = itemId ? cat.items.find(i => i._id === itemId) : null;
            const modal = document.getElementById('modal-content');
            modal.innerHTML = `
                <h3 class="text-xl font-bold mb-4">${item ? 'Editar' : 'Nuevo'} Producto</h3>
                <form id="item-form" class="space-y-4">
                    <div>
                        <label class="block text-sm mb-1">Nombre del Producto</label>
                        <input type="text" id="item-name" value="${item ? item.name : ''}" required class="w-full neumorphic-input p-3 rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Descripción</label>
                        <textarea id="item-desc" class="w-full neumorphic-input p-3 rounded-lg h-20">${item ? item.description : ''}</textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm mb-1">Precio</label>
                            <input type="number" id="item-price" value="${item ? item.basePrice : 0}" required class="w-full neumorphic-input p-3 rounded-lg">
                        </div>
                        <div>
                            <label class="block text-sm mb-1">ID numérico (para orden)</label>
                            <input type="number" id="item-order-id" value="${item ? item.id : 0}" class="w-full neumorphic-input p-3 rounded-lg">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Instrucciones Cocina</label>
                        <input type="text" id="item-kitchen" value="${item ? (item.kitchenGuide || '') : ''}" class="w-full neumorphic-input p-3 rounded-lg">
                    </div>

                    <div class="border-t border-[var(--light-shadow)] pt-4 mt-2">
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="font-bold text-sm text-gray-500 uppercase">Adicionales / Variantes</h3>
                            <button type="button" onclick="addAdicionalRow()" class="text-xs neumorphic-button px-2 py-1 rounded-md flex items-center gap-1">
                                <i data-lucide="plus" class="w-3 h-3"></i> Agregar
                            </button>
                        </div>
                        <div id="adicionales-container" class="space-y-2">
                            <!-- Rows added dynamically -->
                        </div>
                    </div>

                    <div class="md:col-span-2 border-t border-[var(--light-shadow)] pt-4 mt-2">
                        <h3 class="font-bold mb-2 text-sm text-gray-500 uppercase">Mapeo Externo (VinApp)</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-xs mb-1">ID Producto Externo</label>
                                <input type="number" id="item-ext-id" value="${item && item.externalMapping ? item.externalMapping.id_product : ''}" class="w-full neumorphic-input p-3 rounded-lg text-color" placeholder="Ej: 12345">
                            </div>
                            <div>
                                <label class="block text-xs mb-1">ID Compañía (Opcional)</label>
                                <input type="number" id="item-ext-companie" value="${item && item.externalMapping ? (item.externalMapping.id_companie || '') : ''}" class="w-full neumorphic-input p-3 rounded-lg text-color" placeholder="8224">
                            </div>
                            <div>
                                <label class="block text-xs mb-1">ID Punto (Opcional)</label>
                                <input type="number" id="item-ext-point" value="${item && item.externalMapping ? (item.externalMapping.id_point || '') : ''}" class="w-full neumorphic-input p-3 rounded-lg text-color" placeholder="1640">
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="item-active" ${item ? (item.active ? 'checked' : '') : 'checked'} class="w-4 h-4">
                        <label class="text-sm">Producto Activo</label>
                    </div>
                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="flex-grow neumorphic-button py-3 rounded-xl font-bold" style="background-color: var(--primary-color); color: black;">Guardar</button>
                        <button type="button" onclick="closeModal()" class="flex-grow neumorphic-button py-3 rounded-xl font-bold">Cancelar</button>
                    </div>
                </form>
            `;

            if (item && item.adicionales) {
                item.adicionales.forEach(ad => addAdicionalRow(ad));
            }

            document.getElementById('item-form').onsubmit = async (e) => {
                e.preventDefault();
                const extId = document.getElementById('item-ext-id').value;
                const extComp = document.getElementById('item-ext-companie').value;
                const extPoint = document.getElementById('item-ext-point').value;

                const adicionales = [];
                document.querySelectorAll('.adicional-row').forEach(row => {
                    const name = row.querySelector('.ad-name').value;
                    const price = parseInt(row.querySelector('.ad-price').value);
                    const type = row.querySelector('.ad-type').value;
                    if (name) adicionales.push({ name, price: price || 0, type });
                });

                const newItem = {
                    name: document.getElementById('item-name').value,
                    description: document.getElementById('item-desc').value,
                    basePrice: parseInt(document.getElementById('item-price').value),
                    id: parseInt(document.getElementById('item-order-id').value),
                    kitchenGuide: document.getElementById('item-kitchen').value,
                    active: document.getElementById('item-active').checked,
                    adicionales: adicionales,
                    externalMapping: {
                        ...(item ? item.externalMapping : {}),
                        id_product: extId ? parseInt(extId) : null,
                        id_companie: extComp ? parseInt(extComp) : null,
                        id_point: extPoint ? parseInt(extPoint) : null,
                        name_product: document.getElementById('item-name').value,
                        valor: parseInt(document.getElementById('item-price').value)
                    }
                };
                
                let updatedItems;
                if (item) {
                    updatedItems = cat.items.map(i => i._id === item._id ? { ...i, ...newItem } : i);
                } else {
                    updatedItems = [...cat.items, newItem];
                }

                const res = await fetch(`/api/menu-categories/${cat._id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: updatedItems })
                });
                if (res.ok) { closeModal(); loadCategories(); }
            };
            document.getElementById('modal-overlay').classList.remove('hidden');
            lucide.createIcons();
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.add('hidden');
        }

        function editCategory(id) { openCategoryModal(id); }
        async function deleteCategory(id) {
            if (!confirm('¿Seguro? Se borrarán todos los items de esta categoría.')) return;
            await fetch(`/api/menu-categories/${id}`, { method: 'DELETE' });
            loadCategories();
        }

        function editItem(catId, itemId) { openItemModal(catId, itemId); }
        async function deleteItem(catId, itemId) {
            if (!confirm('¿Eliminar producto?')) return;
            const cat = menuCategories.find(c => c._id === catId);
            const updatedItems = cat.items.filter(i => i._id !== itemId);
            await fetch(`/api/menu-categories/${catId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: updatedItems })
            });
            loadCategories();
        }

