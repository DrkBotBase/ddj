                        <label class="block text-sm mb-1 text-amber-500 font-bold">Duración de la Promoción (Minutos)</label>
                        <input type="number" id="promo-duration" class="w-full neumorphic-input p-3 rounded-lg text-color" placeholder="Ej: 30 (Dejar vacío para permanente)" min="1">
                        <p class="text-[10px] text-gray-500 mt-1">${promo && promo.expiresAt ? 'Actualmente expira el: ' + new Date(promo.expiresAt).toLocaleString() : 'La promoción se eliminará automáticamente al pasar este tiempo.'}</p>
                    </div>

                    <div class="border-t border-[var(--light-shadow)] pt-4 mt-2">
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="font-bold text-sm text-gray-500 uppercase">Adicionales / Variantes</h3>
                            <button type="button" onclick="addAdicionalRow()" class="text-xs neumorphic-button px-2 py-1 rounded-md flex items-center gap-1">
                                <i data-lucide="plus" class="w-3 h-3"></i> Agregar
                            </button>
                        </div>
                        <div id="adicionales-container" class="space-y-2">
                            <!-- Rows added dynamically -->
                        </div>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="flex-grow neumorphic-button py-3 rounded-xl font-bold" style="background-color: var(--primary-color); color: black;">Guardar</button>
                        <button type="button" onclick="closeModal()" class="flex-grow neumorphic-button py-3 rounded-xl font-bold">Cancelar</button>
                    </div>
                </form>
            `;

            if (promo && promo.adicionales) {
                promo.adicionales.forEach(ad => addAdicionalRow(ad));
            }

            document.getElementById('promo-form').onsubmit = async (e) => {
                e.preventDefault();
                const durationVal = document.getElementById('promo-duration').value;
                
                const adicionales = [];
                document.querySelectorAll('.adicional-row').forEach(row => {
                    const name = row.querySelector('.ad-name').value;
                    const price = parseInt(row.querySelector('.ad-price').value);
                    const type = row.querySelector('.ad-type').value;
                    if (name) adicionales.push({ name, price: price || 0, type });
                });

                const data = {
                    name: document.getElementById('promo-name').value,
                    description: document.getElementById('promo-description').value,
                    basePrice: parseInt(document.getElementById('promo-basePrice').value),
                    image: document.getElementById('promo-image').value,
                    duration: durationVal ? parseInt(durationVal) : (promo ? null : null),
                    adicionales: adicionales,
                    externalMapping: {
                        id_product: parseInt(document.getElementById('promo-ext-id').value) || null,
                        id_companie: parseInt(document.getElementById('promo-ext-companie').value) || null,
                        id_point: parseInt(document.getElementById('promo-ext-point').value) || null,
                        name_product: document.getElementById('promo-name').value,
                        valor: parseInt(document.getElementById('promo-basePrice').value)
                    }
                };

                const res = await fetch(promo ? `/api/promotions/${promo._id}` : '/api/promotions', {
                    method: promo ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (res.ok) { 
                    closeModal(); 
                    loadPromos(); 
                    showToast(promo ? 'Promoción actualizada' : 'Promoción creada', 'success');
                } else {
                    showToast('Error al guardar la promoción', 'error');
                }
            };
            document.getElementById('modal-overlay').classList.remove('hidden');
            lucide.createIcons();
        }

        function editPromo(id) { openPromoModal(id); }

        async function deletePromo(id) {
            if (confirm('¿Eliminar promoción?')) {
                await fetch(`/api/promotions/${id}`, { method: 'DELETE' });
                loadPromos();
                showToast('Promoción eliminada', 'success');
            }
        }

        // --- Horarios ---
        function renderSchedule() {
            const container = document.getElementById('schedule-inputs');
            container.innerHTML = '';
            const days = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            
            days.forEach((day, index) => {
                const s = restaurantInfo.schedule.find(item => item.day === index) || { open: '18:00', close: '23:30' };
                const div = document.createElement('div');
                div.className = 'grid grid-cols-3 gap-4 items-center';
                div.innerHTML = `
                    <span class="font-bold">${day}</span>
                    <input type="text" name="open_${index}" value="${s.open}" class="neumorphic-input p-2 rounded-lg text-sm" placeholder="18:00 o 24h o closed">
                    <input type="text" name="close_${index}" value="${s.close}" class="neumorphic-input p-2 rounded-lg text-sm" placeholder="23:30">
                `;
                container.appendChild(div);
            });
        }

        document.getElementById('schedule-form').onsubmit = async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const schedule = [];
            for(let i=0; i<7; i++) {
                schedule.push({
                    day: i,
                    open: formData.get(`open_${i}`),
                    close: formData.get(`close_${i}`)
                });
            }
            const res = await fetch('/api/restaurant-info', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ schedule })
            });
            if (res.ok) showToast('Horarios guardados', 'success');
        };

        // --- Envíos ---
        function renderShippingZones() {
            const container = document.getElementById('shipping-zones-container');
            container.innerHTML = '';
            restaurantInfo.shippingZones.forEach((zone, index) => {
                const div = document.createElement('div');
                div.className = 'flex flex-col sm:flex-row gap-3 items-start sm:items-center neumorphic-input p-4 rounded-xl relative';
                div.innerHTML = `
                    <div class="w-full sm:flex-grow">
                        <label class="block text-[10px] uppercase text-gray-500 mb-1 sm:hidden">Nombre de la Zona</label>
                        <input type="text" name="zone_name_${index}" value="${zone.name}" class="w-full bg-transparent outline-none font-bold" placeholder="Nombre de la zona">
                    </div>
                    <div class="w-full sm:w-40 flex items-center gap-2">
                        <label class="block text-[10px] uppercase text-gray-500 sm:hidden">Precio $</label>
                        <input type="number" name="zone_price_${index}" value="${zone.price}" class="w-full bg-transparent outline-none font-bold text-green-600" placeholder="Precio">
                    </div>
                    <button type="button" onclick="removeShippingZone(${index})" class="absolute top-2 right-2 sm:static text-red-500 p-2 hover:bg-red-500/10 rounded-lg transition-colors">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                    </button>
                `;
                container.appendChild(div);
            });
            lucide.createIcons();
        }

        function addShippingZone() {
            restaurantInfo.shippingZones.push({ name: '', price: 0 });
            renderShippingZones();
        }

        function removeShippingZone(index) {
            restaurantInfo.shippingZones.splice(index, 1);
            renderShippingZones();
        }

        document.getElementById('shipping-form').onsubmit = async (e) => {
            e.preventDefault();
            const zones = [];
            const container = document.getElementById('shipping-zones-container');
            const rows = container.children;
            for(let i=0; i<rows.length; i++) {
                const name = rows[i].querySelector(`input[name^="zone_name"]`).value;
                const price = parseInt(rows[i].querySelector(`input[name^="zone_price"]`).value);
                if (name) zones.push({ name, price });
            }
            const res = await fetch('/api/restaurant-info', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ shippingZones: zones })
            });
            if (res.ok) showToast('Zonas guardadas', 'success');
        };

        // --- Notificaciones ---
        document.getElementById('notification-form').onsubmit = async (e) => {
            e.preventDefault();
            const btn = document.getElementById('send-notif-btn');
            const status = document.getElementById('notif-status');
            
            const data = {
                title: document.getElementById('notif-title').value,
                body: document.getElementById('notif-body').value,
                image: document.getElementById('notif-image').value,
                url: document.getElementById('notif-url').value
            };

            if (!confirm('¿Estás seguro de enviar esta notificación a TODOS tus clientes suscritos?')) return;

            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader" class="w-5 h-5 animate-spin"></i> Enviando...';
            lucide.createIcons();
            
            try {
                const res = await fetch('/api/notifications/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await res.json();
                if (result.success) {
                    status.textContent = `¡Éxito! Notificación enviada a ${result.count} suscriptores.`;
                    status.className = 'mt-4 text-center text-sm font-bold text-green-500';
                    e.target.reset();
                } else {
                    status.textContent = 'Error al enviar las notificaciones.';
                    status.className = 'mt-4 text-center text-sm font-bold text-red-500';
                }
            } catch (err) {
                console.error('Error:', err);
                status.textContent = 'Error de conexión con el servidor.';
                status.className = 'mt-4 text-center text-sm font-bold text-red-500';
            } finally {
                status.classList.remove('hidden');
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="send" class="w-5 h-5"></i> Enviar a todos los usuarios';
                lucide.createIcons();
            }
        };

        // --- Clientes ---
        async function loadClients() {
            const list = document.getElementById('clients-list');
            list.innerHTML = '<tr><td colspan="5" class="p-4 text-center">Cargando clientes...</td></tr>';
            
            try {
                const res = await fetch('/api/admin/clients');
                const data = await res.json();
                
                if (data.success) {
                    list.innerHTML = '';
                    if (data.users.length === 0) {
                        list.innerHTML = '<tr><td colspan="5" class="p-4 text-center">No hay clientes registrados aún.</td></tr>';
                        return;
                    }
                    
                    data.users.forEach(user => {
                        const tr = document.createElement('tr');
                        tr.className = 'border-t border-black/10 hover:bg-black/5 transition-colors';
                        tr.innerHTML = `
                            <td class="p-4 font-bold text-color">${user.name}</td>
                            <td class="p-4 text-gray-400">${user.phone}</td>
                            <td class="p-4 text-gray-400 text-xs">${user.address}</td>
                            <td class="p-4 text-center"><span class="bg-blue-500/20 text-blue-400 px-2 py-1 rounded-full text-xs font-bold">${user.orderCount}</span></td>
                            <td class="p-4 font-bold accent-text">$${(user.totalSpent || 0).toLocaleString()}</td>
                            <td class="p-4 text-gray-400 text-xs">${new Date(user.lastOrderAt).toLocaleString()}</td>
                        `;
                        list.appendChild(tr);
                    });
                }
            } catch (err) {
                console.error('Error:', err);
                list.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-red-500">Error al cargar clientes.</td></tr>';
            }
        }

        const originalShowTab = window.showTab;
        window.showTab = (tabName) => {
            if (tabName === 'clients') loadClients();
            if (typeof originalShowTab === 'function') originalShowTab(tabName);
            else {
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.getElementById(`content-${tabName}`).classList.remove('hidden');
                document.getElementById(`tab-${tabName}`).classList.add('active');
            }
        };

        init();
    </script>
</body>
</html>