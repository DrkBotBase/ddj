<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración - <%= restaurantInfo.config.nombre %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
          --bg-color: #edebe4;
          --text-color: #1a1c21;
          --primary-color: #e21c1b;
          --light-shadow: #dbd7c5;
          --dark-shadow: #cac7b5;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Inter', sans-serif;
        }
        .neumorphic-flat {
            background: var(--bg-color);
            box-shadow: 7px 7px 15px var(--dark-shadow), -7px -7px 15px var(--light-shadow);
        }
        .neumorphic-input {
            background: var(--bg-color);
            box-shadow: inset 4px 4px 8px var(--dark-shadow), inset -4px -4px 8px var(--light-shadow);
            border: none;
            outline: none;
        }
        .neumorphic-button {
            background: var(--bg-color);
            box-shadow: 5px 5px 10px var(--dark-shadow), -5px -5px 10px var(--light-shadow);
            transition: all 0.2s ease;
        }
        .neumorphic-button:active {
            box-shadow: inset 3px 3px 6px var(--dark-shadow), inset -3px -3px 6px var(--light-shadow);
            transform: scale(0.98);
        }
        .tab-btn.active {
            color: var(--primary-color);
            box-shadow: inset 3px 3px 6px var(--dark-shadow), inset -3px -3px 6px var(--light-shadow);
        }
        .hidden { display: none; }
        /* Estilos Toast Notification */
        #toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: none;
        }
        .toast {
            background: rgba(23, 23, 27, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid var(--light-shadow);
            color: var(--text-color);
            padding: 12px 20px;
            border-radius: 12px;
            box-shadow: 5px 5px 15px var(--dark-shadow);
            display: flex;
            items-center: center;
            gap: 10px;
            min-width: 250px;
            max-width: 90vw;
            transform: translateX(120%);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: auto;
        }
        .toast.active {
            transform: translateX(0);
        }
        .toast-icon {
            flex-shrink: 0;
        }
        .toast-message {
            font-size: 0.85rem;
            font-weight: 500;
        }
    </style>
</head>
<body class="p-4 md:p-8">
    <div class="max-w-6xl mx-auto">
        <header class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
            <h1 class="text-3xl font-bold" style="color: var(--primary-color);">Panel de Control</h1>
            <div class="flex gap-4">
                <a href="/logout" class="neumorphic-button px-4 py-2 rounded-lg text-sm text-red-500">Cerrar Sesión</a>
                <a href="/" target="_blank" class="neumorphic-button px-4 py-2 rounded-lg text-sm">Ver Sitio Público</a>
            </div>
        </header>

        <nav class="flex flex-wrap gap-2 mb-8">
            <button onclick="showTab('home')" id="tab-home" class="tab-btn active neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="home"></i> Inicio
            </button>
            <button onclick="showTab('history')" id="tab-history" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="list"></i> Historial
            </button>
            <button onclick="showTab('config')" id="tab-config" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="settings"></i> Configuración
            </button>
            <button onclick="showTab('menu')" id="tab-menu" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="utensils"></i> Menú
            </button>
            <button onclick="showTab('promos')" id="tab-promos" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="sparkles"></i> Promociones
            </button>
            <button onclick="showTab('schedule')" id="tab-schedule" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="clock"></i> Horarios
            </button>
            <button onclick="showTab('shipping')" id="tab-shipping" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="truck"></i> Envíos
            </button>
            <button onclick="showTab('notifications')" id="tab-notifications" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="bell"></i> Notificaciones
            </button>
            <button onclick="showTab('clients')" id="tab-clients" class="tab-btn neumorphic-button px-6 py-3 rounded-xl font-bold flex items-center gap-2">
                <i data-lucide="users"></i> Clientes
            </button>
        </nav>

        <div id="content-home" class="tab-content">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Órdenes Pendientes</h2>
                <div id="pending-count" class="bg-yellow-500 text-black px-3 py-1 rounded-full font-bold text-xs">0</div>
            </div>
            <div id="pending-orders-container" class="space-y-6">
            </div>
        </div>

        <div id="content-history" class="tab-content hidden">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Historial de Órdenes</h2>
                <button onclick="loadOrders()" class="neumorphic-button px-4 py-2 rounded-lg text-sm flex items-center gap-2">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i> Actualizar
                </button>
            </div>
            <div class="neumorphic-flat rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-black/20 text-xs uppercase tracking-wider">
                            <tr>
                                <th class="p-4 font-bold">ID</th>
                                <th class="p-4 font-bold">Cliente</th>
                                <th class="p-4 font-bold">Fecha</th>
                                <th class="p-4 font-bold">Total</th>
                                <th class="p-4 font-bold">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="history-list" class="text-sm">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="content-config" class="tab-content hidden">
            <section class="neumorphic-flat rounded-2xl p-6">
                <h2 class="text-xl font-bold mb-6">Datos del Restaurante</h2>
                <form id="config-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm mb-1">Nombre del Negocio</label>
                        <input type="text" name="nombre" value="<%= restaurantInfo.config.nombre %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Dirección</label>
                        <input type="text" name="direccion" value="<%= restaurantInfo.config.direccion %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">WhatsApp (con código país, ej: 57300...)</label>
                        <input type="text" name="telefonoWhatsApp" value="<%= restaurantInfo.config.telefonoWhatsApp %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">URL Logo/Banner</label>
                        <input type="text" name="logoUrl" value="<%= restaurantInfo.config.logoUrl %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div class="md:col-span-2 border-t border-[var(--light-shadow)] pt-4 mt-2">
                        <h3 class="font-bold mb-4">Datos de Transferencia</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm mb-1">Banco / Plataforma</label>
                                <input type="text" name="bankName" value="<%= restaurantInfo.paymentInfo.transfer.bankName %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                            </div>
                            <div>
                                <label class="block text-sm mb-1">Tipo de Cuenta</label>
                                <input type="text" name="accountType" value="<%= restaurantInfo.paymentInfo.transfer.accountType %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                            </div>
                            <div>
                                <label class="block text-sm mb-1">Número de Cuenta/Celular</label>
                                <input type="text" name="accountNumber" value="<%= restaurantInfo.paymentInfo.transfer.accountNumber %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                            </div>
                            <div>
                                <label class="block text-sm mb-1">Titular</label>
                                <input type="text" name="accountHolder" value="<%= restaurantInfo.paymentInfo.transfer.accountHolder %>" class="w-full neumorphic-input p-3 rounded-lg text-color">
                            </div>
                        </div>
                    </div>
                    <div class="md:col-span-2 border-t border-[var(--light-shadow)] pt-4 mt-2">
                        <h3 class="font-bold mb-4">Colores de Marca</h3>
                        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                            <div>
                                <label class="block text-xs mb-1">Primario (Botones)</label>
                                <input type="text" name="color_primary" value="<%= restaurantInfo.config.color.primary %>" class="w-full neumorphic-input p-3 rounded-lg text-xs" placeholder="#0cf106">
                            </div>
                            <div>
                                <label class="block text-xs mb-1">Fondo (Oscuro)</label>
                                <input type="text" name="color_bg" value="<%= restaurantInfo.config.color.bg %>" class="w-full neumorphic-input p-3 rounded-lg text-xs" placeholder="#17171b">
                            </div>
                            <div>
                                <label class="block text-xs mb-1">Texto</label>
                                <input type="text" name="color_text" value="<%= restaurantInfo.config.color.text %>" class="w-full neumorphic-input p-3 rounded-lg text-xs" placeholder="#e0e1e5">
                            </div>
                            <div>
                                <label class="block text-xs mb-1">Sombra Clara</label>
                                <input type="text" name="color_light" value="<%= restaurantInfo.config.color.light %>" class="w-full neumorphic-input p-3 rounded-lg text-xs" placeholder="#262222">
                            </div>
                            <div>
                                <label class="block text-xs mb-1">Sombra Oscura</label>
                                <input type="text" name="color_dark" value="<%= restaurantInfo.config.color.dark %>" class="w-full neumorphic-input p-3 rounded-lg text-xs" placeholder="#000000">
                            </div>
                        </div>
                    </div>
                    <div class="md:col-span-2 mt-4">
                        <button type="submit" class="w-full neumorphic-button py-3 rounded-xl font-bold" style="background-color: var(--primary-color); color: black;">Guardar Configuración</button>
                    </div>
                </form>
            </section>
        </div>

        <div id="content-menu" class="tab-content hidden">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Gestión de Categorías y Productos</h2>
                <button onclick="openCategoryModal()" class="neumorphic-button px-4 py-2 rounded-lg text-sm flex items-center gap-2">
                    <i data-lucide="plus-circle" class="w-4 h-4"></i> Nueva Categoría
                </button>
            </div>
            
            <div id="categories-container" class="space-y-8">
            </div>
        </div>

        <div id="content-promos" class="tab-content hidden">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Gestión de Promociones</h2>
                <button onclick="openPromoModal()" class="neumorphic-button px-4 py-2 rounded-lg text-sm flex items-center gap-2">
                    <i data-lucide="sparkles" class="w-4 h-4"></i> Nueva Promoción
                </button>
            </div>

            <section>
                <h2 class="text-lg font-bold mb-4">Promociones Activas</h2>
                <div id="promos-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                </div>
            </section>
        </div>

        <div id="content-schedule" class="tab-content hidden">
            <section class="neumorphic-flat rounded-2xl p-6">
                <h2 class="text-xl font-bold mb-6">Horarios de Atención</h2>
                <form id="schedule-form" class="space-y-4">
                    <div class="grid grid-cols-1 gap-4" id="schedule-inputs">
                    </div>
                    <button type="submit" class="w-full neumorphic-button py-3 rounded-xl font-bold mt-6" style="background-color: var(--primary-color); color: black;">Guardar Horarios</button>
                </form>
            </section>
        </div>

        <div id="content-shipping" class="tab-content hidden">
            <section class="neumorphic-flat rounded-2xl p-4 md:p-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
                    <h2 class="text-xl font-bold">Zonas de Envío</h2>
                    <button type="button" onclick="addShippingZone()" class="neumorphic-button px-4 py-2 rounded-lg text-sm flex items-center gap-2 w-full sm:w-auto justify-center">
                        <i data-lucide="plus" class="w-4 h-4"></i> Añadir Zona
                    </button>
                </div>
                <form id="shipping-form" class="space-y-4">
                    <div id="shipping-zones-container" class="space-y-6 sm:space-y-4">
                    </div>
                    <button type="submit" class="w-full neumorphic-button py-3 rounded-xl font-bold mt-6" style="background-color: var(--primary-color); color: black;">Guardar Zonas</button>
                </form>
            </section>
        </div>

        <div id="content-notifications" class="tab-content hidden">
            <section class="neumorphic-flat rounded-2xl p-6">
                <h2 class="text-xl font-bold mb-6">Enviar Notificación Push</h2>
                <p class="text-sm text-gray-500 mb-6">Este mensaje llegará directamente a los celulares/computadoras de los clientes que hayan aceptado recibir notificaciones.</p>
                
                <form id="notification-form" class="space-y-4">
                    <div>
                        <label class="block text-sm mb-1">Título de la Notificación</label>
                        <input type="text" id="notif-title" placeholder="Ej: ¡Combo especial hoy!" required class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Mensaje</label>
                        <textarea id="notif-body" placeholder="Ej: Aprovecha nuestro 2x1 en hamburguesas solo por tiempo limitado." required class="w-full neumorphic-input p-3 rounded-lg text-color h-24"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Imagen de la Notificación (URL opcional)</label>
                        <input type="text" id="notif-image" placeholder="https://... (ideal para promocionar platos)" class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div>
                        <label class="block text-sm mb-1">Enlace (URL opcional)</label>
                        <input type="text" id="notif-url" placeholder="https://..." class="w-full neumorphic-input p-3 rounded-lg text-color">
                    </div>
                    <div class="pt-4">
                        <button type="submit" id="send-notif-btn" class="w-full neumorphic-button py-4 rounded-xl font-bold flex items-center justify-center gap-2" style="background-color: var(--primary-color); color: black;">
                            <i data-lucide="send" class="w-5 h-5"></i> Enviar a todos los usuarios
                        </button>
                    </div>
                </form>
                <div id="notif-status" class="mt-4 text-center text-sm font-bold hidden"></div>
            </section>
        </div>

        <div id="content-clients" class="tab-content hidden">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Base de Datos de Clientes</h2>
                <button onclick="loadClients()" class="neumorphic-button px-4 py-2 rounded-lg text-sm flex items-center gap-2">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i> Actualizar
                </button>
            </div>
            <div class="neumorphic-flat rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-black/20 text-xs uppercase tracking-wider">
                            <tr>
                                <th class="p-4 font-bold">Nombre</th>
                                <th class="p-4 font-bold">Teléfono</th>
                                <th class="p-4 font-bold">Dirección</th>
                                <th class="p-4 font-bold">Pedidos</th>
                                <th class="p-4 font-bold">Total Gastado</th>
                                <th class="p-4 font-bold">Último Pedido</th>
                            </tr>
                        </thead>
                        <tbody id="clients-list" class="text-sm">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modales -->
    <div id="modal-overlay" class="fixed inset-0 bg-black/80 hidden z-50 flex items-center justify-center p-4">
        <div id="modal-content" class="neumorphic-flat rounded-2xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
        </div>
    </div>
    
    <div id="toast-container"></div>

    <script>
        let restaurantInfo = <%- JSON.stringify(restaurantInfo) %>;
        let menuCategories = [];
        let allOrders = [];

        async function init() {
            lucide.createIcons();
            loadPromos();
            loadCategories();
            loadOrders();
            renderSchedule();
            renderShippingZones();
            
            setInterval(loadOrders, 30000);
        }

        function showTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('content-' + tabId).classList.remove('hidden');
            document.getElementById('tab-' + tabId).classList.add('active');
            lucide.createIcons();
            
            if (tabId === 'home' || tabId === 'history') renderOrders();
        }
        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast neumorphic-flat`;
            
            let icon = 'info';
            let color = 'text-color';
            toast.style.background = '#fecb15';
            
            if (type === 'success') {
                icon = 'check-circle';
                toast.style.background = '#02f664';
            } else if (type === 'error') {
                icon = 'alert-circle';
                toast.style.background = '#ff3131';
            }

            toast.innerHTML = `
                <div class="toast-icon">
                    <i data-lucide="${icon}" class="w-5 h-5 text-color"></i>
                </div>
                <div class="toast-message text-color">${message}</div>
            `;

            container.appendChild(toast);
            if (typeof lucide !== 'undefined') lucide.createIcons();

            setTimeout(() => toast.classList.add('active'), 10);

            setTimeout(() => {
                toast.classList.remove('active');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        async function loadOrders() {
            try {
                const res = await fetch('/api/admin/orders');
                const data = await res.json();
                if (data.success) {
                    allOrders = data.orders;
                    renderOrders();
                }
            } catch (err) {
                console.error('Error loading orders:', err);
            }
        }

        function renderOrders() {
            const pendingContainer = document.getElementById('pending-orders-container');
            const pendingOrders = allOrders.filter(o => o.status === 'pending');
            document.getElementById('pending-count').textContent = pendingOrders.length;
            
            pendingContainer.innerHTML = '';
            if (pendingOrders.length === 0) {
                pendingContainer.innerHTML = '<p class="text-center py-8 text-gray-400 neumorphic-flat rounded-2xl">No hay órdenes pendientes. ¡Todo al día!</p>';
            } else {
                pendingOrders.forEach(order => {
                    const card = createOrderCard(order);
                    pendingContainer.appendChild(card);
                });
            }

            const historyList = document.getElementById('history-list');
            historyList.innerHTML = '';
            allOrders.forEach(order => {
                const date = new Date(order.createdAt).toLocaleDateString('es-CO');
                const row = document.createElement('tr');
                row.className = 'border-t border-[var(--light-shadow)] hover:bg-white/5 cursor-pointer transition-colors';
                row.onclick = () => openOrderDetails(order._id);
                row.innerHTML = `
                    <td class="p-4 font-bold">#${order.shortId || order._id.slice(-6)}</td>
                    <td class="p-4">${order.clientName}</td>
                    <td class="p-4 text-xs text-gray-400">${date}</td>
                    <td class="p-4 font-bold text-green-500">$${order.total.toLocaleString()}</td>
                    <td class="p-4"><span class="text-[10px] px-2 py-0.5 rounded-full ${getStatusClass(order.status)} uppercase font-bold">${order.status}</span></td>
                `;
                historyList.appendChild(row);
            });
            lucide.createIcons();
        }

        function createOrderCard(order) {
            const date = new Date(order.createdAt).toLocaleString('es-CO');
            const orderEl = document.createElement('div');
            orderEl.className = 'neumorphic-flat rounded-2xl p-6 border-l-4 ' + 
                (order.status === 'completed' ? 'border-green-500' : (order.status === 'cancelled' ? 'border-red-500' : 'border-yellow-500'));
            
            orderEl.innerHTML = `
                <div class="flex flex-col md:flex-row justify-between gap-4 mb-4">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-black text-lg text-color">#${order.shortId || order._id.slice(-6)}</span>
                            <span class="text-xs px-2 py-1 rounded-full ${getStatusClass(order.status)} uppercase font-bold">${order.status}</span>
                        </div>
                        <p class="text-xs text-gray-400">${date}</p>
                    </div>
                    <div class="flex gap-2 h-fit">
                        <select onchange="updateOrderStatus('${order._id}', this.value)" class="neumorphic-input p-2 rounded-lg text-xs">
                            <option value="pending" ${order.status === 'pending' ? 'selected' : ''}>Pendiente</option>
                            <option value="completed" ${order.status === 'completed' ? 'selected' : ''}>Completada</option>
                            <option value="cancelled" ${order.status === 'cancelled' ? 'selected' : ''}>Cancelada</option>
                        </select>
                        <button onclick="deleteOrder('${order._id}')" class="neumorphic-button p-2 rounded-lg text-red-500">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-[var(--light-shadow)] pt-4">
                    <div>
                        <h4 class="font-bold text-sm mb-2 uppercase text-gray-500 tracking-wider">Cliente</h4>
                        <p class="font-bold">${order.clientName}</p>
                        <p class="text-sm">${order.clientPhone}</p>
                        <p class="text-sm text-gray-400">${order.clientAddress}</p>
                    </div>
                    <div>
                        <h4 class="font-bold text-sm mb-2 uppercase text-gray-500 tracking-wider">Pedido</h4>
                        <div class="space-y-1">
                            ${order.items.map(item => `
                                <div class="flex justify-between text-sm">
                                    <span>${item.quantity}x ${item.name}</span>
                                    <span>$${(item.price * item.quantity).toLocaleString()}</span>
                                </div>
                                ${item.adicionales && item.adicionales.length > 0 ? `
                                    <div class="text-[10px] text-gray-400 pl-4">
                                        + ${item.adicionales.map(a => `${a.name} ($${a.price.toLocaleString()})`).join(', ')}
                                    </div>
                                ` : ''}
                            `).join('')}
                        </div>
                        <div class="mt-3 pt-2 border-t border-[var(--light-shadow)] flex justify-between font-bold text-lg" style="color: var(--primary-color);">
                            <span>TOTAL</span>
                            <span>$${order.total.toLocaleString()}</span>
                        </div>
                    </div>
