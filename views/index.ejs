        function addToCart() {
            if (!currentItem) return;
            
            const radioInputs = document.querySelectorAll('.adicional-input[type="radio"]');
            if (radioInputs.length > 0) {
                const selectedRadio = document.querySelector('.adicional-input[type="radio"]:checked');
                if (!selectedRadio) {
                    showToast('Por favor selecciona una variante para continuar', 'error');
                    return;
                }
            }

            const price = calculateItemPrice();
            const quantity = parseInt(itemModal.qty.textContent);
            const instructions = itemModal.instructions.value.trim();
            
            const adicionales = [];
            document.querySelectorAll('.adicional-input:checked').forEach(cb => {
                adicionales.push({
                    name: cb.dataset.name,
                    price: parseFloat(cb.dataset.price)
                });
            });

            const cartId = String(Date.now() + Math.random());

            cart.push({
                id: currentItem.id,
                cartId: cartId,
                name: currentItem.name,
                price: price,
                quantity: quantity,
                isPromo: currentItem.isPromo || false,
                instructions: instructions,
                adicionales: adicionales,
                kitchenGuide: currentItem.kitchenGuide || `${currentItem.name} (Eje del local)`
            });
            
            renderCart();
            toggleModal('item', false);
        }
        
        function renderCart() {
            const formatCOP = value => `$${Intl.NumberFormat('es-CO').format(value)}`;
        
            cartModal.itemsContainer.innerHTML = '';
            if (cart.length === 0) {
                cartModal.itemsContainer.innerHTML = '<p id="empty-cart-msg" class="text-center text-color py-4">Tu carrito está vacío.</p>';
                cartModal.summary.classList.add('hidden');
                cartModal.form.classList.add('hidden');
                cartModal.badge.classList.add('hidden');
                return;
            }
        
            cartModal.summary.classList.remove('hidden');
            cartModal.form.classList.remove('hidden');
        
            cart.forEach(item => {
                const itemEl = document.createElement('div');
                itemEl.className = 'flex justify-between items-center py-3 border-b border-[var(--light-shadow)]';
        
                const totalItem = item.price * item.quantity;
        
                itemEl.innerHTML = `
                    <div class="max-w-[80%]">
                        <p class="font-bold text-color text-sm md:text-base">${item.quantity} x ${item.name}</p>
                        ${item.adicionales && item.adicionales.length > 0 ? `
                            <p class="text-[10px] text-gray-400">
                                + ${item.adicionales.map(a => a.name).join(', ')}
                            </p>
                        ` : ''}
                        ${item.instructions ? `<p class="text-xs text-color italic mt-0.5">Nota: "${item.instructions}"</p>` : ''}
                        <p class="text-sm font-semibold accent-text mt-1">${formatCOP(totalItem)}</p>
                    </div>
                    <button class="remove-btn neumorphic-button p-2.5 rounded-lg text-red-400 hover:text-red-300" data-cart-id="${item.cartId}">
                        <i data-lucide="trash-2" class="w-4 h-4 pointer-events-none"></i>
                    </button>
                `;
                cartModal.itemsContainer.appendChild(itemEl);
            });
        
            lucide.createIcons();
            updateCartSummary();
            updateStatusUI();
        }
        
        function updateCartSummary() {
            const formatCOP = value => `$${Intl.NumberFormat('es-CO').format(value)}`;
            
            const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            
            const shippingCost = calculateShippingCost();
            const total = subtotal + shippingCost;
            
            cartModal.subtotal.textContent = formatCOP(subtotal);
            cartModal.shipping.textContent = formatCOP(shippingCost);
            cartModal.total.textContent = formatCOP(total);
            cartModal.badge.textContent = totalItems;
            cartModal.badge.classList.toggle('hidden', totalItems === 0);
        }
        
