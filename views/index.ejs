            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast neumorphic-flat`;
            
            let icon = 'info';
            let color = 'text-color';
            toast.style.background = '#fecb15';
            
            if (type === 'success') {
                icon = 'check-circle';
                toast.style.background = '#02f664';
            } else if (type === 'error') {
                icon = 'alert-circle';
                toast.style.background = '#ff3131';
            }

            toast.innerHTML = `
                <div class="toast-icon">
                    <i data-lucide="${icon}" class="w-5 h-5 text-color"></i>
