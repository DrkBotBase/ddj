                            <label class="block text-[10px] text-gray-500 mb-1">MONTO EFECTIVO</label>
                            <input type="number" id="multipago-cash" placeholder="$0" class="w-full neumorphic-input p-3 rounded-lg text-sm text-color">
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-500 mb-1">MONTO TRANSFERENCIA</label>
                            <input type="number" id="multipago-transfer" placeholder="$0" class="w-full neumorphic-input p-3 rounded-lg text-sm text-color">
