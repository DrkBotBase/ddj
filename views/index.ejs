        <div id="cart-form-section" class="p-6 border-t border-[var(--dark-shadow)] hidden">
            <h4 class="text-lg font-bold mb-4 accent-text">Datos para el Domicilio</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <input type="text" id="client-name" placeholder="Nombre *" class="neumorphic-input p-3 rounded-lg text-sm text-color">
