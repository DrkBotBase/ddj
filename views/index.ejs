        function sendOrderViaWhatsApp() {
          const clientName = document.getElementById('client-name').value.trim();  
          const clientPhone = document.getElementById('client-phone').value.trim();  
          const clientAddress = document.getElementById('client-address').value.trim();  
          const paymentMethod = document.querySelector('input[name="payment"]:checked').value;  
          const cashAmount = document.getElementById('payment-cash-amount').value.trim();  
          const multiCash = document.getElementById('multipago-cash').value.trim();
          const multiTransfer = document.getElementById('multipago-transfer').value.trim();
          const comments = document.getElementById('order-comments').value.trim();  
          
          const zoneInfo = getCurrentZoneInfo();
          const shippingCost = calculateShippingCost();
          const shippingZoneName = zoneInfo.name;
          const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);  
          const total = subtotal + shippingCost;  
      
          let message = `📦 *NUEVO PEDIDO - ${window.restaurantData.config.nombre}* \n\n`;
          message += `👤 *Cliente:* ${clientName}\n📞 *Teléfono:* ${clientPhone}\n🏠 *Dirección:* ${clientAddress}\n`;
          message += `🚚 *Zona:* ${shippingZoneName} ($${shippingCost.toLocaleString()} COP)\n\n`;
      
          message += `🧾 *DETALLE DEL PEDIDO:*\n`;
          cart.forEach((item, i) => {
            message += `${i + 1}. *${item.name}* (x${item.quantity}) - $${(item.price * item.quantity).toLocaleString()}\n`;
            if (item.adicionales && item.adicionales.length > 0) {
              item.adicionales.forEach(ad => {
                message += `   + ${ad.name} ($${ad.price.toLocaleString()})\n`;
              });
            }
            if (item.instructions && item.instructions.trim() !== '') {
              message += `   _Nota: "${item.instructions}"_\n`;
            }
          });
      
          message += `\n💰 *Subtotal:* $${subtotal.toLocaleString()}\n`;
          message += `🚕 *Domicilio Fijo:* $${shippingCost.toLocaleString()}\n`;
          message += `💵 *Total a pagar:* *$${total.toLocaleString()}*\n`;
          message += `💳 *Método de pago:* ${paymentMethod.toUpperCase()}\n`;
      
          if (paymentMethod === 'efectivo' && cashAmount) {
              message += `💸 *Paga con:* $${parseInt(cashAmount).toLocaleString()} (Llevar cambio)\n`;
          } else if (paymentMethod === 'multipago') {
              message += `🤝 *Distribución:* Efectivo ($${parseInt(multiCash || 0).toLocaleString()}) + Transferencia ($${parseInt(multiTransfer || 0).toLocaleString()})\n`;
          }
      
          if (comments) {
              message += `\n🗒️ *Notas adicionales:* ${comments}\n`;
          }
          
          message += `\n🕒 _Pedido generado desde el portal digital de MJFOOD_`;
      
          const restaurantPhone = window.restaurantData.config.telefonoWhatsApp;
          const whatsappUrl = `https://api.whatsapp.com/send?phone=${restaurantPhone}&text=${encodeURIComponent(message)}`;
          window.open(whatsappUrl, '_blank');
        }
        
        const RESTAURANTE_ID = window.restaurantData.config.extension;
        async function handleLike(event) {
          event.preventDefault();
          const btn = document.getElementById('likeBtn');
          const count = document.getElementById('likeCount');
          
          if (localStorage.getItem('hasLiked_' + RESTAURANTE_ID)) {
              showToast('¡Ya has calificado este restaurante!');
              return;
          }

          try {
            const response = await fetch('/api/like', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            if (data.success) {
                count.innerText = data.count;
                btn.classList.add('text-lime-400');
                localStorage.setItem('hasLiked_' + RESTAURANTE_ID, 'true');
            } else {
                showToast(data.message || 'Error al procesar el like', 'error');
                if (data.message.includes('Ya has dado like')) {
                    localStorage.setItem('hasLiked_' + RESTAURANTE_ID, 'true');
                    btn.classList.add('text-lime-400');
                }
            }
          } catch (error) {
            console.error('Error updating like:', error);
          }
        }
        
        function checkLikeStatus() {
            if (localStorage.getItem('hasLiked_' + RESTAURANTE_ID)) {
                document.getElementById('likeBtn').classList.add('text-lime-400');
            }
        }
        
        document.addEventListener('DOMContentLoaded', () => {
            initializeApp(restaurantData);
            checkLikeStatus();
            checkNotificationPrompt();
            
            const multiCashInput = document.getElementById('multipago-cash');
            const multiTransferInput = document.getElementById('multipago-transfer');

            cartModal.shippingZoneSelect.addEventListener('change', () => {
                updateCartSummary();
                if (cartModal.shippingZoneSelect.value !== "") {
                    document.getElementById('payment-methods-section').classList.remove('hidden');
                }

                const paymentMethod = document.querySelector('input[name="payment"]:checked');
                if (paymentMethod && paymentMethod.value === 'multipago') {
                    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                    const shippingCost = calculateShippingCost();
                    const total = subtotal + shippingCost;
                    
                    const currentCash = parseFloat(multiCashInput.value) || 0;
                    if (multiCashInput.value !== "" || multiTransferInput.value !== "") {
                        if (currentCash <= total) {
                            multiTransferInput.value = total - currentCash;
                        } else {
                            multiCashInput.value = total;
                            multiTransferInput.value = 0;
                        }
                        showToast('Zona cambiada: Revisa los montos de pago.', 'info');
                    }
                }
            });

            multiCashInput.addEventListener('input', () => {
                const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                const shippingCost = calculateShippingCost();
                const total = subtotal + shippingCost;
                const cashVal = parseFloat(multiCashInput.value) || 0;
                
                if (cashVal <= total) {
                    multiTransferInput.value = total - cashVal;
                } else {
                    multiTransferInput.value = 0;
                }
            });

            multiTransferInput.addEventListener('input', () => {
                const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                const shippingCost = calculateShippingCost();
                const total = subtotal + shippingCost;
                const transferVal = parseFloat(multiTransferInput.value) || 0;
                
                if (transferVal <= total) {
                    multiCashInput.value = total - transferVal;
                } else {
                    multiCashInput.value = 0;
                }
            });

            document.body.addEventListener('click', async e => {
                const header = e.target.closest('.category-header');
                if (header) {
                    const clickedAccordion = header.parentElement;
                    const wasActive = clickedAccordion.classList.contains('active');
                    
                    document
                        .querySelectorAll('.category-accordion')
                        .forEach(acc => acc.classList.remove('active'));

                    if (!wasActive) clickedAccordion.classList.add('active');
                }

                const selectBtn = e.target.closest('.select-item-btn');
                if (selectBtn) {
                    const itemId = parseInt(selectBtn.dataset.id);
                    const item = window.restaurantData.menu
                        .flatMap(cat => cat.items)
                        .find(i => i.id === itemId);

                    if (item) openItemModal(item);
                }
            });

            cartModal.confirmBtn.addEventListener('click', async () => {
              if (validateCartForm()) {
                const paymentMethod = document.querySelector('input[name="payment"]:checked').value;
                const orderData = {
                    clientName: document.getElementById('client-name').value.trim(),
                    clientPhone: document.getElementById('client-phone').value.trim(),
                    clientAddress: document.getElementById('client-address').value.trim(),
                    items: cart.map(item => ({
                        name: item.name,
                        quantity: item.quantity,
                        price: item.price,
                        instructions: item.instructions,
                        adicionales: item.adicionales || []
                    })),
                    subtotal: cart.reduce((sum, item) => sum + (item.price * item.quantity), 0),
                    shippingCost: calculateShippingCost(),
                    total: cart.reduce((sum, item) => sum + (item.price * item.quantity), 0) + calculateShippingCost(),
                    paymentMethod: paymentMethod,
                    cashAmount: (paymentMethod === 'multipago' ? document.getElementById('multipago-cash').value.trim() : document.getElementById('payment-cash-amount').value.trim()) || 0,
                    transferAmount: (paymentMethod === 'multipago' ? document.getElementById('multipago-transfer').value.trim() : 0) || 0,
                    comments: document.getElementById('order-comments').value.trim()
                };

                try {
                    const response = await fetch('/api/orders', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(orderData)
                    });
                    
                    if (response.ok) {
                        saveClientData();
                        sendOrderViaWhatsApp();
                        toggleModal('cart', false);
                        toggleModal('success', true);
                        cart = [];
                        renderCart();

                        document.getElementById('order-comments').value = '';
                        document.getElementById('payment-cash-amount').value = '';
                        document.getElementById('multipago-cash').value = '';
                        document.getElementById('multipago-transfer').value = '';
                        document.getElementById('efectivo-details').style.display = 'none';
                        document.getElementById('transferencia-details').style.display = 'none';
                        document.getElementById('multipago-details').style.display = 'none';

                        const checkedPayment = document.querySelector('input[name="payment"]:checked');
                        if (checkedPayment) checkedPayment.checked = false;

                        cartModal.shippingZoneSelect.value = "";
                    } else {
                        showToast('Error al guardar el pedido. Por favor intenta de nuevo.', 'error');
                    }
                } catch (error) {
                    console.error('Error saving order:', error);
                    showToast('Error de conexión. Por favor intenta de nuevo.');
                }
              }
            });

            document.getElementById('hours-button')
                .addEventListener('click', () => toggleModal('hours', true));

            document.getElementById('close-hours-btn')
                .addEventListener('click', () => toggleModal('hours', false));

            modals.hours.overlay
                .addEventListener('click', () => toggleModal('hours', false));

            document.getElementById('cart-button')
                .addEventListener('click', () => {
                    renderCart();
                    toggleModal('cart', true);
                });

            modals.item.overlay
                .addEventListener('click', () => toggleModal('item', false));

            document.getElementById('close-item-modal-btn')
                .addEventListener('click', () => toggleModal('item', false));

            modals.cart.overlay
                .addEventListener('click', () => toggleModal('cart', false));

            document.getElementById('close-cart-btn')
                .addEventListener('click', () => toggleModal('cart', false));

            modals.success.overlay
                .addEventListener('click', () => toggleModal('success', false));

            document.getElementById('close-success-btn')
                .addEventListener('click', () => toggleModal('success', false));

            document.getElementById('item-decrease-qty')
                .addEventListener('click', () => {
                    let qty = parseInt(itemModal.qty.textContent);
                    if (qty > 1) {
                        itemModal.qty.textContent = qty - 1;
                        calculateItemPrice();
                    }
                });

            document.getElementById('item-increase-qty')
                .addEventListener('click', () => {
                    let qty = parseInt(itemModal.qty.textContent);
                    itemModal.qty.textContent = qty + 1;
                    calculateItemPrice();
                });

            itemModal.addBtn.addEventListener('click', addToCart);

            cartModal.itemsContainer.addEventListener('click', e => {
                const removeBtn = e.target.closest('.remove-btn');
                if (removeBtn) {
                    const cartId = removeBtn.dataset.cartId;
                    cart = cart.filter(item => String(item.cartId) !== String(cartId));
                    renderCart();
                }
            });

            document.querySelectorAll('input[name="payment"]').forEach(radio => {
                radio.addEventListener('change', e => {
                    document.getElementById('efectivo-details').style.display =
                        e.target.value === 'efectivo' ? 'block' : 'none';

                    document.getElementById('transferencia-details').style.display =
                        e.target.value === 'transferencia' ? 'block' : 'none';

                    document.getElementById('multipago-details').style.display =
                        e.target.value === 'multipago' ? 'block' : 'none';
                });
            });
        });

        // --- Banners ---
        let deferredPrompt;
        const pwaBanner = document.getElementById('pwa-install-banner');
        const notifBanner = document.getElementById('notif-subscribe-banner');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            if (!sessionStorage.getItem('pwa_dismissed')) {
                setTimeout(() => {
                    pwaBanner.classList.remove('hidden');
                    setTimeout(() => pwaBanner.classList.add('active'), 100);
                }, 3000);
            }
        });

        document.getElementById('pwa-install-btn').addEventListener('click', async () => {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                const { outcome } = await deferredPrompt.userChoice;
                if (outcome === 'accepted') {
                    pwaBanner.classList.remove('active');
                }
                deferredPrompt = null;
            }
        });

        document.getElementById('pwa-dismiss-btn').addEventListener('click', () => {
            pwaBanner.classList.remove('active');
            sessionStorage.setItem('pwa_dismissed', 'true');
        });

        async function checkNotificationPrompt() {
            if (isPWA() && 'Notification' in window && Notification.permission === 'default') {
                if (!localStorage.getItem('notif_dismissed') && !localStorage.getItem('notif_subscribed')) {
                    setTimeout(() => {
                        notifBanner.classList.remove('hidden');
                        setTimeout(() => notifBanner.classList.add('active'), 100);
                    }, 4000);
                }
            }
        }

        document.getElementById('notif-subscribe-btn').addEventListener('click', async () => {
            const permission = await Notification.requestPermission();
            if (permission === 'granted') {
                notifBanner.classList.remove('active');
                if ('serviceWorker' in navigator) {
                    navigator.serviceWorker.ready.then(reg => subscribeUser(reg, true));
                }
            } else {
                notifBanner.classList.remove('active');
                localStorage.setItem('notif_dismissed', 'true');
            }
        });

        document.getElementById('notif-dismiss-btn').addEventListener('click', () => {
            notifBanner.classList.remove('active');
            localStorage.setItem('notif_dismissed', 'true');
        });

        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(registration => {
                        console.log('ServiceWorker registration successful with scope: ', registration.scope);
                    })
                    .catch(err => {
                        console.log('ServiceWorker registration failed: ', err);
                    });
            });
        }

        function getDeviceId() {
            let deviceId = localStorage.getItem('push_device_id');
            if (!deviceId) {
                deviceId = 'dev_' + Math.random().toString(36).substr(2, 9) + Date.now().toString(36);
                localStorage.setItem('push_device_id', deviceId);
            }
            return deviceId;
        }

        function isPWA() {
            return window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone || document.referrer.includes('android-app://');
        }

        async function subscribeUser(registration, force = false) {
            console.log('Push subscription attempt. Force:', force, 'PWA Mode:', isPWA());
            try {
                const currentVapidKey = VAPID_PUBLIC_KEY;
                const savedVapidKey = localStorage.getItem('last_vapid_key');
                const lastEnv = localStorage.getItem('last_env');
                const currentEnv = isPWA() ? 'pwa' : 'browser';
                
                let existingSubscription = await registration.pushManager.getSubscription();
                
                if (existingSubscription && (force || savedVapidKey !== currentVapidKey || lastEnv !== currentEnv)) {
                    console.log('Environment change or VAPID mismatch. Refreshing subscription...');
                    await existingSubscription.unsubscribe();
                    existingSubscription = null;
                    localStorage.removeItem('notif_subscribed');
                }

                if (existingSubscription) {
                    console.log('Existing subscription valid. Syncing with server...');
                    localStorage.setItem('notif_subscribed', 'true');
                    localStorage.setItem('last_env', currentEnv);
                    const subscriptionData = existingSubscription.toJSON();
                    subscriptionData.deviceId = getDeviceId();
                    await fetch('/api/notifications/subscribe', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(subscriptionData)
                    });
                    return;
                }

                const permission = await Notification.requestPermission();
                if (permission !== 'granted') {
                    console.warn('Notification permission not granted');
                    return;
                }

                console.log('Creating NEW subscription for', currentEnv);
                const subscription = await registration.pushManager.subscribe({
                    userVisibleOnly: true,
                    applicationServerKey: urlBase64ToUint8Array(currentVapidKey.trim())
                });

                const subscriptionData = subscription.toJSON();
                subscriptionData.deviceId = getDeviceId();
                localStorage.setItem('last_vapid_key', currentVapidKey);
                localStorage.setItem('last_env', currentEnv);

                const response = await fetch('/api/notifications/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(subscriptionData)
                });

                if (response.ok) {
                    localStorage.setItem('notif_subscribed', 'true');
                    console.log('New subscription saved successfully');
                    showToast('¡Notificaciones activadas!', 'success');
                } else {
                    console.error('Server failed to save subscription');
                }
            } catch (error) {
                console.error('Failed to subscribe user:', error);
                showToast('Error al activar notificaciones', 'error');
            }
        }

        function urlBase64ToUint8Array(base64String) {
            const padding = '='.repeat((4 - base64String.length % 4) % 4);
            const base64 = (base64String + padding)
                .replace(/\-/g, '+')
                .replace(/_/g, '/');
            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);
            for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
        }
    </script>
</body>
</html>
