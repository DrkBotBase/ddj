        function renderPromotions() {
            const container = document.getElementById('promotions-container');
            const section = document.getElementById('promotions-section');
            
            const staticPromos = window.restaurantData.promotions || [];
            const dbPromos = window.dbPromotions || [];

            if (staticPromos.length === 0 && dbPromos.length === 0) {
                section.classList.add('hidden');
                return;
            }

            section.classList.remove('hidden');
            container.innerHTML = '';

            staticPromos.forEach(promo => {
                const baseItem = window.restaurantData.menu
                    .flatMap(cat => cat.items)
                    .find(i => i.id === promo.itemId);

                if (baseItem) {
                    const item = { ...baseItem, isPromo: true };
                    renderPromoCard(item, promo.image, container);
                }
            });

            dbPromos.forEach(promo => {
                let item;
                if (promo.itemId) {
                    const baseItem = window.restaurantData.menu
                        .flatMap(cat => cat.items)
                        .find(i => i.id === promo.itemId);
                    if (baseItem) {
                        item = { ...baseItem, isPromo: true };
                    }
                } else {
                    item = {
                        id: promo._id,
                        name: promo.name,
                        description: promo.description,
                        basePrice: promo.basePrice,
                        image: promo.image,
                        adicionales: promo.adicionales || [],
                        isPromo: true,
                        kitchenGuide: `PROMO: ${promo.name}`
                    };
                }

                if (item) {
                    renderPromoCard(item, promo.image, container);
                }
            });
        }

